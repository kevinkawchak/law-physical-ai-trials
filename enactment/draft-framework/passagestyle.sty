% passagestyle.sty - style for the H. R. 9510 passage framework (draft-framework).
% Built on the adoption template appearance (adoption/final-framework/publication/
% frameworkstyle.sty) so the visual structure is preserved: Linux Libertine body,
% the title rule, the accent abstract box, and the L/C/Y table columns. Only the
% palette changes for this project: the template accent is #4B0082 (indigo) and the
% figure palette is black, grayscales, #4B0082, #000080 (navy), and #C0C0C0
% (silver). It adds a colored TikZ primitive (psgfig) that reproduces each Mermaid
% figure natively in LaTeX (no raster image), and a psgcaption that places a uniform
% \vspace{-0.75cm} between every figure and its caption.
\NeedsTeXFormat{LaTeX2e}\ProcessOptions\relax

% --- Body font and narrative paper geometry -----------------------------------
\usepackage{libertine}\renewcommand{\sfdefault}{phv}
\usepackage[letterpaper]{geometry}
\AtBeginDocument{%
  \newgeometry{textheight=9in,textwidth=6.4in,top=1in,headheight=15pt,headsep=18pt,footskip=30pt}%
  \setlength{\headwidth}{\textwidth}}

\usepackage{xcolor}
\definecolor{accentcol}{HTML}{4B0082}   % template accent: indigo (authority, the bill)
\definecolor{navyblue}{HTML}{000080}    % navy: evidence and support
\definecolor{silvergray}{HTML}{C0C0C0}  % silver: cost and caution
\definecolor{pg1}{HTML}{F2F2F2}         % light gray (inputs)
\definecolor{pg2}{HTML}{D9D9D9}         % mid gray (steps)
\definecolor{pg3}{HTML}{BFBFBF}         % darker gray (boundaries)
\usepackage[T1]{fontenc}\usepackage[utf8]{inputenc}\usepackage{textcomp}
\usepackage{array}\usepackage{booktabs}\usepackage{tabularx}\usepackage{ragged2e}
\usepackage{needspace}\usepackage{enumitem}\usepackage{graphicx}
\usepackage{float}\usepackage{caption}\usepackage{fancyvrb}\usepackage{microtype}

% --- Even spacing, no overflow, no stranded lines (prompt formatting rules) ----
% Draft-framework: \flushbottom (the template default); maximal widow and club
% penalties keep no single line stranded and no one or two word last line behind.
% The final-framework switches to \raggedbottom as a senior-author finishing step.
\widowpenalty=10000 \clubpenalty=10000 \brokenpenalty=10000
\flushbottom \sloppy \emergencystretch=3em \tolerance=2000
\hyphenpenalty=200 \exhyphenpenalty=200
\newcommand{\shorttitle}{H. R. 9510 passage framework}
\usepackage{fancyhdr}\fancyhf{}\pagestyle{fancy}\renewcommand{\headrulewidth}{0.3pt}
\rhead{\small\color{accentcol}\thepage}\lhead{\footnotesize\itshape\color{accentcol}\shorttitle}

% --- Left-aligned, ragged-right fixed-width columns; flexible Y -----------------
% Every fixed width carries \raggedright\arraybackslash so there are no large
% inter-word gaps, and widths are chosen for the amount of text each column holds.
\newcolumntype{L}[1]{>{\raggedright\arraybackslash}p{#1}}
\newcolumntype{C}[1]{>{\centering\arraybackslash}p{#1}}
\newcolumntype{R}[1]{>{\raggedright\arraybackslash}p{#1}}
\newcolumntype{Y}{>{\raggedright\arraybackslash}X}

% --- Headings (accent, sans, ragged right) ------------------------------------
\makeatletter
\renewcommand{\section}{\@startsection{section}{1}{\z@}{-2.2ex \@plus -0.5ex}{1.3ex}%
  {\large\bfseries\sffamily\color{accentcol}\raggedright}}
\renewcommand{\subsection}{\@startsection{subsection}{2}{\z@}{-1.5ex \@plus -0.4ex}{0.5ex}%
  {\normalsize\bfseries\sffamily\color{accentcol}\raggedright}}
\setlength{\parindent}{\z@}\setlength{\parskip}{5.2\p@}

% --- Title block and abstract box ---------------------------------------------
\renewcommand{\maketitle}{\par\begingroup\thispagestyle{empty}\@maketitle\endgroup\let\maketitle\relax}
\renewcommand{\@maketitle}{\vbox{\hsize\textwidth\linewidth\hsize \vskip 0.1in
  {\color{accentcol}\rule{\textwidth}{3pt}}\vskip 0.14in
  \raggedright {\LARGE\bfseries\sffamily\color{accentcol}\@title\par}\vskip 0.18in
  {\large\@author}\vskip 0.08in {\small\@date}\vskip 0.16in
  {\color{accentcol}\rule{\textwidth}{1pt}}\vskip 0.1in}}
\renewenvironment{abstract}{\par\noindent\colorbox{accentcol!8}{\parbox{\dimexpr\textwidth-2\fboxsep}{%
  {\bfseries\color{accentcol} Abstract.}\quad}}\par\vskip 0.3em\begin{quote}}{\end{quote}}
\makeatother

% --- Text-based ORCID mark (no raster image) ----------------------------------
\newcommand{\orcidicon}[1]{\href{https://orcid.org/#1}{\textsuperscript{\scriptsize\color{accentcol}\,iD}}}

% --- Keywords and back-matter heading ------------------------------------------
\providecommand{\keywordname}{\textbf{Keywords}}
\providecommand{\keywords}[1]{\par\addvspace{\medskipamount}%
  {\setlength{\parindent}{0pt}\keywordname\enspace #1\par}}
\makeatletter
\providecommand{\bmhead}[1]{\par\addvspace{0.5\baselineskip}\needspace{2\baselineskip}%
  \phantomsection\addcontentsline{toc}{section}{#1}{\noindent\bfseries\color{accentcol}#1}\par\addvspace{2pt}}
\makeatother

% --- Colored TikZ Mermaid primitive (reproduces each Mermaid figure) ----------
% Node roles mirror the Mermaid classDef set: psgact (#4B0082, white), psgevid
% (#000080, white), psgcaut (#C0C0C0), and three gray levels for inputs, steps, and
% boundaries. Box width and minimum height are uniform so spacing between boxes is
% even; curved edges always specify an explicit looseness.
\usepackage{tikz}
\usetikzlibrary{shapes.geometric,arrows.meta,positioning,fit,backgrounds,calc}
\tikzset{
  psgevery/.style={>={Stealth[length=2.2mm]},line width=0.5pt,font=\footnotesize,
    every node/.append style={align=center}},
  psgact/.style={rectangle,rounded corners=2pt,draw=black,line width=0.9pt,
    fill=accentcol,text=white,minimum height=8mm,inner sep=3pt,text width=30mm},
  psgevid/.style={rectangle,rounded corners=2pt,draw=black,line width=0.9pt,
    fill=navyblue,text=white,minimum height=8mm,inner sep=3pt,text width=30mm},
  psgcaut/.style={rectangle,rounded corners=2pt,draw=black,fill=silvergray,
    minimum height=8mm,inner sep=3pt,text width=30mm},
  psgone/.style={rectangle,rounded corners=2pt,draw=black,fill=pg1,
    minimum height=8mm,inner sep=3pt,text width=30mm},
  psgtwo/.style={rectangle,rounded corners=2pt,draw=black,fill=pg2,
    minimum height=8mm,inner sep=3pt,text width=30mm},
  psgthree/.style={rectangle,rounded corners=2pt,draw=black,fill=pg3,
    minimum height=8mm,inner sep=3pt,text width=30mm},
  psgdec/.style={diamond,aspect=1.5,draw=black,line width=0.9pt,fill=accentcol,
    text=white,inner sep=1pt,text width=15mm},
  psgperson/.style={ellipse,draw=black,fill=pg1,inner sep=2pt,
    text width=24mm,minimum height=9mm},
  psgedge/.style={->,draw=black},
  psgedged/.style={->,draw=black,dashed},
  psglabel/.style={font=\scriptsize\itshape,fill=white,inner sep=1pt}
}
\newsavebox{\psgsavebox}
\newenvironment{psgfig}{%
  \par\addvspace{0.55\baselineskip}\needspace{8\baselineskip}%
  \begin{lrbox}{\psgsavebox}\begin{tikzpicture}[psgevery]%
}{%
  \end{tikzpicture}\end{lrbox}%
  \begin{center}\setlength{\fboxrule}{0.4pt}\setlength{\fboxsep}{8pt}%
  \fcolorbox{black}{white}{\usebox{\psgsavebox}}\end{center}}
% Uniform figure-to-caption gap: every caption begins with \vspace{-0.75cm}.
\newcommand{\psgcaption}[1]{%
  \vspace{-0.75cm}%
  \par\nopagebreak\begin{center}\begin{minipage}{0.92\linewidth}%
  \footnotesize\itshape\color{black}#1\end{minipage}\end{center}\par\addvspace{0.4\baselineskip}}

\usepackage[hidelinks]{hyperref}\usepackage{url}
\captionsetup{font=small,labelfont=bf,justification=raggedright,singlelinecheck=false}
\endinput
